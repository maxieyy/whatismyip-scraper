{
  "functions": {
    "api/index.py": {
      "runtime": "python3.9",
      "includeFiles": "**/*.py",
      "excludeFiles": ""
    }
  },
  "routes": [
    {
      "src": "/api/lookup",
      "dest": "/api/index.py"
    },
    {
      "src": "/api/lookup/batch",
      "dest": "/api/index.py",
      "methods": ["POST"]
    },
    {
      "src": "/api/health",
      "dest": "/api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.py"
    }
  ]
}
